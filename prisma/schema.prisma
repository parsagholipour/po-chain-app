model CustomFieldDefinition {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  fieldKey       String
  type           CustomFieldType
  entityType     String
  required       Boolean         @default(false)
  sortOrder      Int             @default(0)
  conditionLogic ConditionLogic  @default(and)
  storeId        String          @db.Uuid
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  createdById    String          @db.Uuid
  createdBy      User            @relation("CustomFieldDefinitionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  values     CustomFieldValue[]
  conditions CustomFieldCondition[]

  @@unique([storeId, entityType, fieldKey])
  @@index([storeId, entityType, sortOrder])
}

model CustomFieldCondition {
  id           String                @id @default(uuid()) @db.Uuid
  definitionId String                @db.Uuid
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  sourceField  String
  operator     ConditionOperator
  value        String                @default("")
  createdAt    DateTime              @default(now())

  @@index([definitionId])
}

model CustomFieldValue {
  id           String                @id @default(uuid()) @db.Uuid
  definitionId String                @db.Uuid
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  entityId     String                @db.Uuid
  textValue    String?
  numberValue  Decimal?              @db.Decimal(12, 2)
  dateValue    DateTime?
  booleanValue Boolean?
  fileKey      String?
  storeId      String                @db.Uuid
  store        Store                 @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([definitionId, entityId])
  @@index([storeId, entityId])
}

model OrderStatusLog {
  id                   String   @id @default(uuid()) @db.Uuid
  fromStatus           String
  toStatus             String
  note                 String?
  purchaseOrderId      String?  @db.Uuid
  manufacturingOrderId String?  @db.Uuid
  warehouseOrderId     String?  @db.Uuid
  shippingId           String?  @db.Uuid
  storeId              String   @db.Uuid
  createdAt            DateTime @default(now())
  createdById          String   @db.Uuid

  purchaseOrder      PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  manufacturingOrder ManufacturingOrder? @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  warehouseOrder     WarehouseOrder?     @relation(fields: [warehouseOrderId], references: [id], onDelete: Cascade)
  shipping           Shipping?           @relation(fields: [shippingId], references: [id], onDelete: Cascade)
  store              Store               @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdBy          User                @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([storeId, createdAt])
  @@index([storeId, purchaseOrderId, createdAt])
  @@index([storeId, manufacturingOrderId, createdAt])
  @@index([storeId, warehouseOrderId, createdAt])
  @@index([storeId, shippingId, createdAt])
}

model Notification {
  id            String               @id @default(uuid()) @db.Uuid
  type          NotificationType
  priority      NotificationPriority @default(info)
  audience      NotificationAudience
  title         String
  body          String               @db.Text
  href          String?
  entityType    String?
  entityId      String?              @db.Uuid
  dedupeKey     String
  data          Json?
  saleChannelId String?              @db.Uuid
  storeId       String               @db.Uuid
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  createdById   String?              @db.Uuid

  saleChannel     SaleChannel?                @relation(fields: [saleChannelId], references: [id], onDelete: SetNull)
  store           Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy       User?                       @relation("NotificationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reads           NotificationRead[]
  emailDeliveries NotificationEmailDelivery[]

  @@unique([storeId, dedupeKey])
  @@index([storeId, audience, createdAt])
  @@index([storeId, saleChannelId, audience, createdAt])
  @@index([storeId, type, createdAt])
  @@index([storeId, entityType, entityId])
}

model NotificationRead {
  notificationId String   @db.Uuid
  userId         String   @db.Uuid
  readAt         DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([notificationId, userId])
  @@index([userId, readAt])
}

model NotificationEmailDelivery {
  id             String                          @id @default(uuid()) @db.Uuid
  notificationId String                          @db.Uuid
  recipientEmail String?
  recipientName  String?
  status         NotificationEmailDeliveryStatus @default(pending)
  attemptCount   Int                             @default(0)
  nextAttemptAt  DateTime?
  sentAt         DateTime?
  messageId      String?
  lastError      String?                         @db.Text
  storeId        String                          @db.Uuid
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt, createdAt])
  @@index([storeId, status, createdAt])
  @@index([notificationId])
}
