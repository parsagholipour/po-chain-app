model Shipping {
  id                    String               @id @default(uuid()) @db.Uuid
  type                  ShippingType
  status                ShippingStatus       @default(pending)
  cost                  Decimal?             @db.Decimal(12, 2)
  deliveryDutiesPaid    Boolean              @default(false)
  trackingNumber        String
  shippedAt             DateTime?
  trackingLink          String?
  notes                 String?
  invoiceDocumentKey    String?
  logisticsPartnerId    String?              @db.Uuid
  logisticsPartner      LogisticsPartner?    @relation(fields: [logisticsPartnerId], references: [id], onDelete: SetNull)
  saleChannelLocationId String?              @db.Uuid
  saleChannelLocation   SaleChannelLocation? @relation(fields: [saleChannelLocationId], references: [id], onDelete: SetNull)
  shipToLocationName    String?
  shipToRecipientName   String?
  shipToCompanyName     String?
  shipToPhoneNumber     String?
  shipToEmail           String?
  shipToAddressLine1    String?
  shipToAddressLine2    String?
  shipToCity            String?
  shipToStateProvince   String?
  shipToPostalCode      String?
  shipToCountry         String?
  shipToNotes           String?
  storeId               String               @db.Uuid
  store                 Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  createdById           String               @db.Uuid
  createdBy             User                 @relation("ShippingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturingOrderShippings ManufacturingOrderShipping[]
  purchaseOrderShippings      PurchaseOrderShipping[]
  warehouseOrderShippings     WarehouseOrderShipping[]
  statusLogs                  OrderStatusLog[]

  @@index([storeId, type, status])
