  createdBy   User                 @relation("WarehouseOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  purchaseOrders          WarehouseOrderPurchaseOrder[]
  lineAllocations         WarehouseOrderPurchaseOrderLine[]
  warehouseOrderShippings WarehouseOrderShipping[]
  statusLogs              OrderStatusLog[]

  @@index([storeId, status])
  @@index([storeId, warehouseId])
  @@index([storeId, number])
  @@index([storeId, createdAt])
}

model ManufacturingOrderManufacturer {
  manufacturingOrderId String                               @db.Uuid
  manufacturerId       String                               @db.Uuid
  status               ManufacturingOrderManufacturerStatus @default(initial)
  invoiceId            String?                              @unique @db.Uuid
  storeId              String                               @db.Uuid
  store                Store                                @relation(fields: [storeId], references: [id], onDelete: Restrict)

  depositPaidAt      DateTime?
  depositPaidAmount  Decimal?  @db.Decimal(12, 2)
  depositRefNumber   String?
  depositDocumentKey String?
  depositNote        String?

  manufacturingStartedAt DateTime?
  estimatedCompletionAt  DateTime?
  manufacturingNote      String?

  balancePaidAt      DateTime?
  balancePaidAmount  Decimal?  @db.Decimal(12, 2)
  balanceRefNumber   String?
  balanceDocumentKey String?
  balanceNote        String?

  readyAt      DateTime?
  readyNote    String?
  pickedUpAt   DateTime?
  pickedUpNote String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid
  createdBy   User     @relation("MOManufacturerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  manufacturer       Manufacturer       @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  invoice            Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@id([manufacturingOrderId, manufacturerId])
  @@index([storeId, manufacturerId])
  @@index([storeId, invoiceId])
  @@index([storeId, depositPaidAt])
  @@index([storeId, balancePaidAt])
  @@index([storeId, manufacturingStartedAt])
  @@index([storeId], where: raw("\"depositPaidAt\" IS NOT NULL AND \"balancePaidAt\" IS NULL"), name: "MOM_storeId_outstanding_balance_idx")
}

model ManufacturingOrderPurchaseOrder {
  manufacturingOrderId String @db.Uuid
  purchaseOrderId      String @db.Uuid
  storeId              String @db.Uuid
  store                Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
