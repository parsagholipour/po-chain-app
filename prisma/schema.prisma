// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SaleChannelType {
  distributor
  amazon
  cjdropshipping
}

/// Row kind for `PurchaseOrder`: distributor PO vs internal stock order (same table).
enum PurchaseOrderType {
  distributor
  stock
}

/// Distributor / logistics lifecycle on the purchase order
enum PurchaseOrderStatus {
  open
  in_transit
  closed
}

/// Manufacturing workflow status on the manufacturing order
enum ManufacturingOrderStatus {
  open
  ready_to_ship
  shipped
  invoiced
  paid
  closed
}

enum ManufacturingOrderManufacturerStatus {
  initial
  deposit_paid
  manufacturing
  balance_paid
  ready_to_pickup
  picked_up
}

enum ShippingType {
  manufacturing_order
  purchase_order
  stock_order
}

enum ShippingStatus {
  pending
  in_transit
  delivered
  cancelled
}

enum LogisticsPartnerType {
  freight_forwarder
  carrier
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  keycloakSub String   @unique @db.Uuid
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manufacturersCreated                    Manufacturer[]                       @relation("ManufacturerCreatedBy")
  saleChannelsCreated                     SaleChannel[]                        @relation("SaleChannelCreatedBy")
  productsCreated                         Product[]                            @relation("ProductCreatedBy")
  invoicesCreated                         Invoice[]                            @relation("InvoiceCreatedBy")
  purchaseOrdersCreated                   PurchaseOrder[]                      @relation("PurchaseOrderCreatedBy")
  purchaseOrderLinesCreated               PurchaseOrderLine[]                  @relation("POLineCreatedBy")
  manufacturingOrdersCreated              ManufacturingOrder[]                 @relation("ManufacturingOrderCreatedBy")
  manufacturingOrderManufacturersCreated  ManufacturingOrderManufacturer[]     @relation("MOManufacturerCreatedBy")
  logisticsPartnersCreated                LogisticsPartner[]                   @relation("LogisticsPartnerCreatedBy")
  shippingsCreated                        Shipping[]                           @relation("ShippingCreatedBy")
  manufacturingOrderPurchaseOrderLinesCreated ManufacturingOrderPurchaseOrderLine[] @relation("MOPurchaseOrderLineCreatedBy")
}

model Manufacturer {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  logoKey     String?
  region      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid
  createdBy   User     @relation("ManufacturerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  productsAsDefault Product[] @relation("ProductDefaultManufacturer")
  onManufacturingOrders ManufacturingOrderManufacturer[]
  onMoLines         ManufacturingOrderPurchaseOrderLine[]
}

model SaleChannel {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  logoKey     String?
  type        SaleChannelType
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdById String          @db.Uuid
  createdBy   User            @relation("SaleChannelCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  purchaseOrders              PurchaseOrder[]
}

model Product {
  id                    String       @id @default(uuid()) @db.Uuid
  name                  String
  sku                   String       @unique
  imageKey              String?
  barcodeKey            String?
  packagingKey          String?
  defaultManufacturerId String       @db.Uuid
  defaultManufacturer   Manufacturer @relation("ProductDefaultManufacturer", fields: [defaultManufacturerId], references: [id], onDelete: Restrict)
  verified              Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  createdById           String       @db.Uuid
  createdBy             User         @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  purchaseOrderLines PurchaseOrderLine[]
}

model Invoice {
  id                      String    @id @default(uuid()) @db.Uuid
  orderDate               DateTime?
  estimatedCompletionDate DateTime?
  invoiceNumber           String    @unique
  documentKey             String?
  depositPaidAt           DateTime?
  balancePaidAt           DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  createdById             String    @db.Uuid
  createdBy               User      @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturingOrderManufacturer ManufacturingOrderManufacturer?
}

model PurchaseOrder {
  id            String              @id @default(uuid()) @db.Uuid
  number        Int                 @unique @default(autoincrement())
  name          String
  type          PurchaseOrderType   @default(distributor)
  status        PurchaseOrderStatus @default(open)
  documentKey   String?
  saleChannelId String?             @db.Uuid
  saleChannel   SaleChannel?        @relation(fields: [saleChannelId], references: [id], onDelete: Restrict)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  createdById   String              @db.Uuid
  createdBy     User                @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  lines                        PurchaseOrderLine[]
  manufacturingOrderPurchaseOrders ManufacturingOrderPurchaseOrder[]
  purchaseOrderShippings       PurchaseOrderShipping[]
}

model PurchaseOrderLine {
  id              String   @id @default(uuid()) @db.Uuid
  purchaseOrderId String   @db.Uuid
  productId       String   @db.Uuid
  quantity        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String   @db.Uuid
  createdBy       User     @relation("POLineCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  manufacturingOrderLines ManufacturingOrderPurchaseOrderLine[]
}

model ManufacturingOrder {
  id           String                   @id @default(uuid()) @db.Uuid
  number       Int                      @unique @default(autoincrement())
  name         String
  status       ManufacturingOrderStatus @default(open)
  documentKey  String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  createdById  String                   @db.Uuid
  createdBy    User                     @relation("ManufacturingOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturers ManufacturingOrderManufacturer[]
  purchaseOrders  ManufacturingOrderPurchaseOrder[]
  lineAllocations ManufacturingOrderPurchaseOrderLine[]
  manufacturingOrderShippings ManufacturingOrderShipping[]
}

model ManufacturingOrderManufacturer {
  manufacturingOrderId String                           @db.Uuid
  manufacturerId       String                           @db.Uuid
  status               ManufacturingOrderManufacturerStatus @default(initial)
  invoiceId            String?                          @unique @db.Uuid

  depositPaidAt           DateTime? @map("deposit_paid_at")
  depositPaidAmount       Decimal?  @db.Decimal(12, 2) @map("deposit_paid_amount")
  depositTrackingNumber   String?   @map("deposit_tracking_number")
  depositDocumentKey      String?   @map("deposit_document_key")

  manufacturingStartedAt  DateTime? @map("manufacturing_started_at")

  balancePaidAt           DateTime? @map("balance_paid_at")
  balancePaidAmount       Decimal?  @db.Decimal(12, 2) @map("balance_paid_amount")
  balanceTrackingNumber   String?   @map("balance_tracking_number")
  balanceDocumentKey      String?   @map("balance_document_key")

  readyAt                 DateTime? @map("ready_at")
  pickedUpAt              DateTime? @map("picked_up_at")

  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt
  createdById          String                           @db.Uuid
  createdBy            User                             @relation("MOManufacturerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  manufacturer       Manufacturer       @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  invoice            Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@id([manufacturingOrderId, manufacturerId])
}

model ManufacturingOrderPurchaseOrder {
  manufacturingOrderId String @db.Uuid
  purchaseOrderId    String @db.Uuid

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  purchaseOrder      PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@id([manufacturingOrderId, purchaseOrderId])
}

model LogisticsPartner {
  id            String               @id @default(uuid()) @db.Uuid
  name          String
  logoKey       String?
  contactNumber String?
  link          String?
  type          LogisticsPartnerType
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  createdById   String               @db.Uuid
  createdBy     User                 @relation("LogisticsPartnerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  shippings Shipping[]
}

model Shipping {
  id                 String         @id @default(uuid()) @db.Uuid
  type               ShippingType
  status             ShippingStatus @default(pending)
  trackingNumber     String
  shippedAt          DateTime?
  trackingLink       String?
  notes              String?
  invoiceDocumentKey String?
  logisticsPartnerId String?        @db.Uuid
  logisticsPartner   LogisticsPartner? @relation(fields: [logisticsPartnerId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  createdById        String         @db.Uuid
  createdBy          User           @relation("ShippingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturingOrderShippings ManufacturingOrderShipping[]
  purchaseOrderShippings      PurchaseOrderShipping[]
}

model ManufacturingOrderShipping {
  manufacturingOrderId String @db.Uuid
  shippingId           String @db.Uuid

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  shipping           Shipping           @relation(fields: [shippingId], references: [id], onDelete: Cascade)

  @@id([manufacturingOrderId, shippingId])
}

model PurchaseOrderShipping {
  purchaseOrderId String @db.Uuid
  shippingId      String @db.Uuid

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  shipping      Shipping      @relation(fields: [shippingId], references: [id], onDelete: Cascade)

  @@id([purchaseOrderId, shippingId])
}

model ManufacturingOrderPurchaseOrderLine {
  manufacturingOrderId   String   @db.Uuid
  purchaseOrderLineId    String   @db.Uuid
  manufacturerId         String   @db.Uuid
  verified               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdById            String   @db.Uuid
  createdBy              User     @relation("MOPurchaseOrderLineCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Cascade)
  purchaseOrderLine  PurchaseOrderLine  @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Cascade)
  manufacturer       Manufacturer       @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)

  @@id([manufacturingOrderId, purchaseOrderLineId])
}
