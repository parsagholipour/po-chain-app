// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  previewFeatures = ["partialIndexes"]
  output          = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SaleChannelType {
  distributor
  store
  amazon
  cjdropshipping
}

enum UserType {
  internal
  distributor
}

/// Row kind for `PurchaseOrder`: distributor PO vs internal stock order (same table).
enum PurchaseOrderType {
  distributor
  stock
}

/// Distributor / logistics lifecycle on the purchase order
enum PurchaseOrderStatus {
  open
  in_transit
  invoiced
  closed
}

enum InvoicePurpose {
  manual
  distributor_order
}

enum InvoicePaymentStatus {
  unpaid
  pending
  paid
  failed
  cancelled
}

enum DraftPurchaseOrderStatus {
  pending_payment
  paid
  converted
  cancelled
}

enum PaymentAttemptStatus {
  created
  pending
  paid
  failed
  cancelled
  expired
}

/// Manufacturing workflow status on the manufacturing order
enum ManufacturingOrderStatus {
  open
  ready_to_ship
  shipped
  invoiced
  paid
  closed
}

/// Warehouse fulfillment workflow status on the warehouse order
enum WarehouseOrderStatus {
  open
  shipped
  closed
}

enum ManufacturingOrderManufacturerStatus {
  initial
  deposit_paid
  manufacturing
  balance_paid
  ready_to_pickup
  picked_up
}

enum ShippingType {
  manufacturing_order
  purchase_order
  stock_order
  warehouse_order
}

enum ShippingStatus {
  pending
  in_transit
  delivered
  cancelled
}

enum LogisticsPartnerType {
  freight_forwarder
  carrier
}

enum CustomFieldType {
  text
  number
  date
  boolean
  file
  image
}

enum ConditionLogic {
  and
  or
}

enum ConditionOperator {
  equals
  not_equals
  greater_than
  less_than
  greater_than_or_equal
  less_than_or_equal
  contains
  not_empty
  is_empty
}

/// OS&D (Over / Short / Damage) on a distributor purchase order
enum PurchaseOrderOsdType {
  overage
  shortage
  damage
}

enum PurchaseOrderOsdResolution {
  charged
  returned
  sent
}

enum ProductEditingStatus {
  standard
  final_stock
  one_print_only
}

enum NotificationType {
  purchase_order_created
  external_order_created
  payment_failed
  payment_cancelled
  po_status_changed
  shipment_status_changed
  backorder_actualized
  po_osd_created
}

enum NotificationPriority {
  info
  important
  urgent
}

enum NotificationAudience {
  store_owner
  distributor
}

enum NotificationEmailDeliveryStatus {
  pending
  sent
  failed
  skipped
}

model Store {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  email     String?
  website   String?
  logoKey   String?
  theme     Json     @default("{\"primaryColor\":\"rgb(110 46 143)\",\"primaryForegroundColor\":\"rgb(255 255 255)\",\"logoHueRotateDeg\":120}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userStores                           UserStore[]
  manufacturers                        Manufacturer[]
  warehouses                           Warehouse[]
  saleChannels                         SaleChannel[]
  saleChannelLocations                 SaleChannelLocation[]
  saleChannelMagicLinks                SaleChannelMagicLink[]
  products                             Product[]
  invoices                             Invoice[]
  purchaseOrders                       PurchaseOrder[]
  purchaseOrderLines                   PurchaseOrderLine[]
  manufacturingOrders                  ManufacturingOrder[]
  warehouseOrders                      WarehouseOrder[]
  manufacturingOrderManufacturers      ManufacturingOrderManufacturer[]
  manufacturingOrderPurchaseOrders     ManufacturingOrderPurchaseOrder[]
  warehouseOrderPurchaseOrders         WarehouseOrderPurchaseOrder[]
  logisticsPartners                    LogisticsPartner[]
  shippings                            Shipping[]
  manufacturingOrderShippings          ManufacturingOrderShipping[]
  purchaseOrderShippings               PurchaseOrderShipping[]
  warehouseOrderShippings              WarehouseOrderShipping[]
  manufacturingOrderPurchaseOrderLines ManufacturingOrderPurchaseOrderLine[]
  warehouseOrderPurchaseOrderLines     WarehouseOrderPurchaseOrderLine[]
  customFieldDefinitions               CustomFieldDefinition[]
  customFieldValues                    CustomFieldValue[]
  shopifyIntegration                   ShopifyIntegration?
  paymentProviderSettings              StorePaymentProviderSetting[]
  productStockSnapshotBackups          ProductStockSnapshotBackup[]
  productCategories                    ProductCategory[]
  productTypes                         ProductType[]
  productCollections                   ProductCollection[]
  purchaseOrderOsds                    PurchaseOrderOsd[]
  purchaseOrderOsdLines                PurchaseOrderOsdLine[]
  orderStatusLogs                      OrderStatusLog[]
  draftPurchaseOrders                  DraftPurchaseOrder[]
  draftPurchaseOrderLines              DraftPurchaseOrderLine[]
  paymentAttempts                      PaymentAttempt[]
  paymentWebhookEvents                 PaymentWebhookEvent[]
  notifications                        Notification[]
  notificationEmailDeliveries          NotificationEmailDelivery[]

  @@index([name])
}

model ShopifyIntegration {
  id                         String    @id @default(uuid()) @db.Uuid
  storeId                    String    @unique @db.Uuid
  store                      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shopDomain                 String
  enabled                    Boolean   @default(false)
  accessTokenEncrypted       String?   @db.Text
  webhookSecretEncrypted     String?   @db.Text
  webhookSubscriptionId      String?
  lastSyncAt                 DateTime?
  lastSyncStatus             String?
  lastSyncError              String?   @db.Text
  lastSyncedProductCount     Int       @default(0)
  lastMatchedSkuCount        Int       @default(0)
  lastUnmatchedLocalSkuCount Int       @default(0)
  syncLockUntil              DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([enabled])
  @@index([syncLockUntil])
}

model StorePaymentProviderSetting {
  id                     String   @id @default(uuid()) @db.Uuid
  storeId                String   @db.Uuid
  store                  Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider               String
  enabled                Boolean  @default(false)
  currency               String   @default("usd")
  secretKeyEncrypted     String?  @db.Text
  webhookSecretEncrypted String?  @db.Text
  secretKeyLast4         String?
  webhookSecretLast4     String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdById            String   @db.Uuid
  createdBy              User     @relation("PaymentProviderSettingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById            String?  @db.Uuid
  updatedBy              User?    @relation("PaymentProviderSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([storeId, provider])
  @@index([provider, enabled])
  @@index([storeId, enabled])
}

model ProductStockSnapshotBackup {
  id           String   @id @default(uuid()) @db.Uuid
  storeId      String   @db.Uuid
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  snapshotDate DateTime @db.Date
  objectKey    String
  fileName     String
  contentType  String
  size         Int
  productCount Int
  createdAt    DateTime @default(now())

  @@unique([storeId, snapshotDate])
  @@index([storeId, createdAt])
}

model UserStore {
  userId    String   @db.Uuid
  storeId   String   @db.Uuid
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@index([storeId])
}

model User {
  id            String       @id @default(uuid()) @db.Uuid
  keycloakSub   String       @unique @db.Uuid
  email         String       @unique
  name          String?
  realEmail     String?
  realName      String?
  type          UserType     @default(internal)
  saleChannelId String?      @unique @db.Uuid
  saleChannel   SaleChannel? @relation("SaleChannelLoginUser", fields: [saleChannelId], references: [id], onDelete: Restrict)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  userStores                                  UserStore[]
  manufacturersCreated                        Manufacturer[]                        @relation("ManufacturerCreatedBy")
  warehousesCreated                           Warehouse[]                           @relation("WarehouseCreatedBy")
  saleChannelsCreated                         SaleChannel[]                         @relation("SaleChannelCreatedBy")
  saleChannelLocationsCreated                 SaleChannelLocation[]                 @relation("SaleChannelLocationCreatedBy")
  saleChannelMagicLinksCreated                SaleChannelMagicLink[]                @relation("SaleChannelMagicLinkCreatedBy")
  productsCreated                             Product[]                             @relation("ProductCreatedBy")
  invoicesCreated                             Invoice[]                             @relation("InvoiceCreatedBy")
  draftPurchaseOrdersCreated                  DraftPurchaseOrder[]                  @relation("DraftPurchaseOrderCreatedBy")
  draftPurchaseOrderLinesCreated              DraftPurchaseOrderLine[]              @relation("DraftPOLineCreatedBy")
  paymentAttemptsCreated                      PaymentAttempt[]                      @relation("PaymentAttemptCreatedBy")
  paymentProviderSettingsCreated              StorePaymentProviderSetting[]         @relation("PaymentProviderSettingCreatedBy")
  paymentProviderSettingsUpdated              StorePaymentProviderSetting[]         @relation("PaymentProviderSettingUpdatedBy")
  purchaseOrdersCreated                       PurchaseOrder[]                       @relation("PurchaseOrderCreatedBy")
  purchaseOrderLinesCreated                   PurchaseOrderLine[]                   @relation("POLineCreatedBy")
  manufacturingOrdersCreated                  ManufacturingOrder[]                  @relation("ManufacturingOrderCreatedBy")
  warehouseOrdersCreated                      WarehouseOrder[]                      @relation("WarehouseOrderCreatedBy")
  manufacturingOrderManufacturersCreated      ManufacturingOrderManufacturer[]      @relation("MOManufacturerCreatedBy")
  logisticsPartnersCreated                    LogisticsPartner[]                    @relation("LogisticsPartnerCreatedBy")
  shippingsCreated                            Shipping[]                            @relation("ShippingCreatedBy")
  manufacturingOrderPurchaseOrderLinesCreated ManufacturingOrderPurchaseOrderLine[] @relation("MOPurchaseOrderLineCreatedBy")
  warehouseOrderPurchaseOrderLinesCreated     WarehouseOrderPurchaseOrderLine[]     @relation("WOPurchaseOrderLineCreatedBy")
  customFieldDefinitionsCreated               CustomFieldDefinition[]               @relation("CustomFieldDefinitionCreatedBy")
  productCategoriesCreated                    ProductCategory[]                     @relation("ProductCategoryCreatedBy")
  productTypesCreated                         ProductType[]                         @relation("ProductTypeCreatedBy")
  productCollectionsCreated                   ProductCollection[]                   @relation("ProductCollectionCreatedBy")
  purchaseOrderOsdsCreated                    PurchaseOrderOsd[]                    @relation("PurchaseOrderOsdCreatedBy")
  orderStatusLogsCreated                      OrderStatusLog[]
  notificationsCreated                        Notification[]                        @relation("NotificationCreatedBy")
  notificationReads                           NotificationRead[]
  appSessions                                 AppSession[]
}

model AppSession {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  keycloakSub       String    @db.Uuid
  keycloakSessionId String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())
  revokedAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, lastSeenAt])
  @@index([keycloakSub])
  @@index([keycloakSessionId])
}

model Manufacturer {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  logoKey       String?
  region        String
  contactNumber String?
  address       String?
  email         String?
  link          String?
  notes         String?
  storeId       String   @db.Uuid
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String   @db.Uuid
  createdBy     User     @relation("ManufacturerCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  productsAsDefault     Product[]                             @relation("ProductDefaultManufacturer")
  onManufacturingOrders ManufacturingOrderManufacturer[]
  onMoLines             ManufacturingOrderPurchaseOrderLine[]

  @@index([storeId, name])
  @@index([storeId, createdAt])
}

model Warehouse {
  id            String       @id @default(uuid()) @db.Uuid
  name          String
  address       String?
  phoneNumber   String?
  email         String?
  saleChannelId String?      @db.Uuid
  saleChannel   SaleChannel? @relation(fields: [saleChannelId], references: [id], onDelete: Restrict)
  storeId       String       @db.Uuid
  store         Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   String       @db.Uuid
  createdBy     User         @relation("WarehouseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  warehouseOrders WarehouseOrder[]

  @@index([storeId, name])
  @@index([storeId, saleChannelId])
  @@index([storeId, createdAt])
}

model SaleChannel {
  id            String          @id @default(uuid()) @db.Uuid
  name          String
  logoKey       String?
  type          SaleChannelType
  contactNumber String?
  link          String?
  email         String?
  address       String?
  notes         String?
  storeId       String          @db.Uuid
  store         Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdById   String          @db.Uuid
  createdBy     User            @relation("SaleChannelCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  purchaseOrders      PurchaseOrder[]
  warehouses          Warehouse[]
  locations           SaleChannelLocation[]
  magicLinks          SaleChannelMagicLink[]
  loginUser           User?                  @relation("SaleChannelLoginUser")
  draftPurchaseOrders DraftPurchaseOrder[]
  notifications       Notification[]

  @@index([storeId, type, name])
  @@index([storeId, createdAt])
}

model SaleChannelLocation {
  id            String      @id @default(uuid()) @db.Uuid
  name          String
  recipientName String
  companyName   String?
  phoneNumber   String?
  email         String?
  addressLine1  String
  addressLine2  String?
  city          String
  stateProvince String?
  postalCode    String?
  country       String
  shippingNotes String?
  saleChannelId String      @db.Uuid
  saleChannel   SaleChannel @relation(fields: [saleChannelId], references: [id], onDelete: Restrict)
  storeId       String      @db.Uuid
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  createdById   String      @db.Uuid
  createdBy     User        @relation("SaleChannelLocationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  purchaseOrders      PurchaseOrder[]
  shippings           Shipping[]
  draftPurchaseOrders DraftPurchaseOrder[]

  @@index([storeId, saleChannelId, name])
  @@index([storeId, createdAt])
}

model SaleChannelMagicLink {
  id            String      @id @default(uuid()) @db.Uuid
  tokenHash     String      @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  lastUsedAt    DateTime?
  useCount      Int         @default(0)
  saleChannelId String      @db.Uuid
  saleChannel   SaleChannel @relation(fields: [saleChannelId], references: [id], onDelete: Cascade)
  storeId       String      @db.Uuid
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  createdById   String      @db.Uuid
  createdBy     User        @relation("SaleChannelMagicLinkCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([storeId, saleChannelId, expiresAt])
  @@index([storeId, revokedAt])
}

model Product {
  id                    String               @id @default(uuid()) @db.Uuid
  name                  String
  sku                   String
  upcGtin               String?
  cost                  Decimal?             @db.Decimal(12, 2)
  price                 Decimal?             @db.Decimal(12, 2)
  mop                   Int?
  map                   Decimal?             @db.Decimal(12, 2)
  msrp                  Decimal?             @db.Decimal(12, 2)
  quantityPerCarton     Int?
  orderByDate           DateTime?
  editingStatus         ProductEditingStatus @default(standard)
  description           String?
  imageLink             String               @default("")
  stockCount            Int?
  imageKey              String?
  barcodeKey            String?
  packagingKey          String?
  defaultManufacturerId String               @db.Uuid
  defaultManufacturer   Manufacturer         @relation("ProductDefaultManufacturer", fields: [defaultManufacturerId], references: [id], onDelete: Restrict)
  categoryId            String?              @db.Uuid
  category              ProductCategory?     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  typeId                String?              @db.Uuid
  type                  ProductType?         @relation(fields: [typeId], references: [id], onDelete: Restrict)
  collectionId          String?              @db.Uuid
  collection            ProductCollection?   @relation(fields: [collectionId], references: [id], onDelete: Restrict)
  verified              Boolean              @default(false)
  storeId               String               @db.Uuid
  store                 Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  createdById           String               @db.Uuid
  createdBy             User                 @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  purchaseOrderLines      PurchaseOrderLine[]
  draftPurchaseOrderLines DraftPurchaseOrderLine[]

  @@unique([storeId, sku])
  @@index([storeId, name])
  @@index([storeId, defaultManufacturerId])
  @@index([storeId, categoryId])
  @@index([storeId, typeId])
  @@index([storeId, collectionId])
  @@index([storeId, upcGtin])
  @@index([storeId, editingStatus])
  @@index([storeId, orderByDate])
  @@index([storeId, createdAt])
  @@index([storeId, verified])
  @@index([storeId], where: raw("\"cost\" IS NULL OR \"price\" IS NULL"), name: "Product_storeId_missing_pricing_idx")
}

model ProductCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  storeId     String   @db.Uuid
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid
  createdBy   User     @relation("ProductCategoryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  products Product[]

  @@index([storeId, name])
  @@index([storeId, createdAt])
}

model ProductType {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  storeId     String   @db.Uuid
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid
  createdBy   User     @relation("ProductTypeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  products Product[]

  @@index([storeId, name])
  @@index([storeId, createdAt])
}

model ProductCollection {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  storeId     String   @db.Uuid
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String   @db.Uuid
  createdBy   User     @relation("ProductCollectionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  products Product[]

  @@index([storeId, name])
  @@index([storeId, createdAt])
}

model Invoice {
  id             String               @id @default(uuid()) @db.Uuid
  invoiceNumber  String
  documentKey    String?
  purpose        InvoicePurpose       @default(manual)
  paymentStatus  InvoicePaymentStatus @default(unpaid)
  currency       String               @default("usd")
  subtotalAmount Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal              @default(0) @db.Decimal(12, 2)
  paidAt         DateTime?
  storeId        String               @db.Uuid
  store          Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  createdById    String               @db.Uuid
  createdBy      User                 @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturingOrderManufacturer ManufacturingOrderManufacturer?
  purchaseOrders                 PurchaseOrder[]
  draftPurchaseOrders            DraftPurchaseOrder[]
  paymentAttempts                PaymentAttempt[]
  paymentWebhookEvents           PaymentWebhookEvent[]

  @@unique([storeId, invoiceNumber])
  @@index([storeId, purpose, paymentStatus])
  @@index([storeId, createdAt])
}

model PurchaseOrder {
  id                    String               @id @default(uuid()) @db.Uuid
  number                Int                  @unique @default(autoincrement())
  name                  String
  type                  PurchaseOrderType    @default(distributor)
  status                PurchaseOrderStatus  @default(open)
  invoiceId             String?              @db.Uuid
  invoice               Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  documentKey           String?
  saleChannelId         String?              @db.Uuid
  saleChannel           SaleChannel?         @relation(fields: [saleChannelId], references: [id], onDelete: Restrict)
  saleChannelLocationId String?              @db.Uuid
  saleChannelLocation   SaleChannelLocation? @relation(fields: [saleChannelLocationId], references: [id], onDelete: Restrict)
  isBackOrder           Boolean              @default(false)
  actualizedPoId        String?              @unique @db.Uuid
  actualizedPo          PurchaseOrder?       @relation("BackOrderActualization", fields: [actualizedPoId], references: [id], onDelete: SetNull)
  shipToLocationName    String?
  shipToRecipientName   String?
  shipToCompanyName     String?
  shipToPhoneNumber     String?
  shipToEmail           String?
  shipToAddressLine1    String?
  shipToAddressLine2    String?
  shipToCity            String?
  shipToStateProvince   String?
  shipToPostalCode      String?
  shipToCountry         String?
  shipToNotes           String?
  storeId               String               @db.Uuid
  store                 Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  createdById           String               @db.Uuid
  createdBy             User                 @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  lines                            PurchaseOrderLine[]
  manufacturingOrderPurchaseOrders ManufacturingOrderPurchaseOrder[]
  warehouseOrderPurchaseOrders     WarehouseOrderPurchaseOrder[]
  purchaseOrderShippings           PurchaseOrderShipping[]
  osds                             PurchaseOrderOsd[]
  statusLogs                       OrderStatusLog[]
  draftSource                      DraftPurchaseOrder?               @relation("DraftConvertedPurchaseOrder")
  backOrderSources                 PurchaseOrder[]                   @relation("BackOrderActualization")

  @@index([storeId, type, status])
  @@index([storeId, type, isBackOrder, status])
  @@index([storeId, type, status, updatedAt])
  @@index([storeId, number])
  @@index([storeId, saleChannelId])
  @@index([storeId, saleChannelLocationId])
  @@index([storeId, createdAt])
  @@index([storeId, invoiceId])
}

model DraftPurchaseOrder {
  id                       String                   @id @default(uuid()) @db.Uuid
  name                     String
  status                   DraftPurchaseOrderStatus @default(pending_payment)
  documentKey              String?
  invoiceId                String                   @db.Uuid
  invoice                  Invoice                  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  saleChannelId            String                   @db.Uuid
  saleChannel              SaleChannel              @relation(fields: [saleChannelId], references: [id], onDelete: Restrict)
  saleChannelLocationId    String?                  @db.Uuid
  saleChannelLocation      SaleChannelLocation?     @relation(fields: [saleChannelLocationId], references: [id], onDelete: Restrict)
  isBackOrder              Boolean                  @default(false)
  destinationKey           String
  shipToLocationName       String?
  shipToRecipientName      String?
  shipToCompanyName        String?
  shipToPhoneNumber        String?
  shipToEmail              String?
  shipToAddressLine1       String?
  shipToAddressLine2       String?
  shipToCity               String?
  shipToStateProvince      String?
  shipToPostalCode         String?
  shipToCountry            String?
  shipToNotes              String?
  convertedPurchaseOrderId String?                  @unique @db.Uuid
  convertedPurchaseOrder   PurchaseOrder?           @relation("DraftConvertedPurchaseOrder", fields: [convertedPurchaseOrderId], references: [id], onDelete: SetNull)
  storeId                  String                   @db.Uuid
  store                    Store                    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  createdById              String                   @db.Uuid
  createdBy                User                     @relation("DraftPurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  lines DraftPurchaseOrderLine[]

  @@unique([invoiceId, destinationKey, isBackOrder])
  @@index([storeId, invoiceId])
  @@index([storeId, saleChannelId])
  @@index([storeId, saleChannelLocationId])
  @@index([storeId, status])
  @@index([storeId, createdAt])
}

model DraftPurchaseOrderLine {
  id                   String             @id @default(uuid()) @db.Uuid
  draftPurchaseOrderId String             @db.Uuid
  draftPurchaseOrder   DraftPurchaseOrder @relation(fields: [draftPurchaseOrderId], references: [id], onDelete: Cascade)
  productId            String             @db.Uuid
  product              Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity             Int
  unitCost             Decimal?           @db.Decimal(12, 2)
  unitPrice            Decimal            @db.Decimal(12, 2)
  lineTotal            Decimal            @db.Decimal(12, 2)
  storeId              String             @db.Uuid
  store                Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  createdById          String             @db.Uuid
  createdBy            User               @relation("DraftPOLineCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([storeId, draftPurchaseOrderId])
  @@index([storeId, productId])
  @@index([storeId, createdAt])
}

model PaymentAttempt {
  id                      String               @id @default(uuid()) @db.Uuid
  provider                String
  status                  PaymentAttemptStatus @default(created)
  amount                  Decimal              @db.Decimal(12, 2)
  currency                String               @default("usd")
  providerSessionId       String?              @unique
  providerPaymentIntentId String?
  checkoutUrl             String?
  failureMessage          String?
  invoiceId               String               @db.Uuid
  invoice                 Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  storeId                 String               @db.Uuid
  store                   Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  createdById             String               @db.Uuid
  createdBy               User                 @relation("PaymentAttemptCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  webhookEvents PaymentWebhookEvent[]

  @@index([storeId, invoiceId])
  @@index([storeId, provider, status])
  @@index([storeId, createdAt])
}

model PaymentWebhookEvent {
  id               String          @id @default(uuid()) @db.Uuid
  provider         String
  providerEventId  String
  type             String
  paymentAttemptId String?         @db.Uuid
  paymentAttempt   PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)
