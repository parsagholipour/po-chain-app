  @@unique([provider, providerEventId])
  @@index([storeId, processedAt])
  @@index([invoiceId])
  @@index([paymentAttemptId])
}

model PurchaseOrderLine {
  id              String   @id @default(uuid()) @db.Uuid
  purchaseOrderId String   @db.Uuid
  productId       String   @db.Uuid
  quantity        Int
  /// Distributor-ordered quantity; `quantity` is effective units after OS&D deltas (analytics).
  orderedQuantity Int
  unitCost        Decimal? @db.Decimal(12, 2)
  unitPrice       Decimal? @db.Decimal(12, 2)
  storeId         String   @db.Uuid
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String   @db.Uuid
  createdBy       User     @relation("POLineCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  manufacturingOrderLines ManufacturingOrderPurchaseOrderLine[]
  warehouseOrderLines     WarehouseOrderPurchaseOrderLine[]
  osdLines                PurchaseOrderOsdLine[]

  @@index([storeId, purchaseOrderId])
  @@index([storeId, productId])
  @@index([storeId, createdAt])
  @@index([storeId], where: raw("\"unitCost\" IS NULL OR \"unitPrice\" IS NULL"), name: "PurchaseOrderLine_storeId_missing_pricing_idx")
}

model PurchaseOrderOsd {
  id                   String                     @id @default(uuid()) @db.Uuid
  purchaseOrderId      String                     @db.Uuid
  type                 PurchaseOrderOsdType
  resolution           PurchaseOrderOsdResolution
  manufacturingOrderId String?                    @db.Uuid
  documentKey          String?
  notes                String?
  storeId              String                     @db.Uuid
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  createdById          String                     @db.Uuid

  purchaseOrder      PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  store              Store                  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdBy          User                   @relation("PurchaseOrderOsdCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  manufacturingOrder ManufacturingOrder?    @relation(fields: [manufacturingOrderId], references: [id], onDelete: SetNull)
  lines              PurchaseOrderOsdLine[]

  @@index([storeId, purchaseOrderId])
  @@index([storeId, createdAt])
  @@index([storeId, manufacturingOrderId])
}

model PurchaseOrderOsdLine {
  id                  String   @id @default(uuid()) @db.Uuid
  osdId               String   @db.Uuid
  purchaseOrderLineId String   @db.Uuid
  quantity            Int
  storeId             String   @db.Uuid
  createdAt           DateTime @default(now())

  osd               PurchaseOrderOsd  @relation(fields: [osdId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)
  store             Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@index([storeId, osdId])
  @@index([storeId, purchaseOrderLineId])
}

model ManufacturingOrder {
  id          String                   @id @default(uuid()) @db.Uuid
  number      Int                      @unique @default(autoincrement())
  name        String
  status      ManufacturingOrderStatus @default(open)
  documentKey String?
  storeId     String                   @db.Uuid
  store       Store                    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  createdById String                   @db.Uuid
  createdBy   User                     @relation("ManufacturingOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  manufacturers               ManufacturingOrderManufacturer[]
  purchaseOrders              ManufacturingOrderPurchaseOrder[]
  lineAllocations             ManufacturingOrderPurchaseOrderLine[]
  manufacturingOrderShippings ManufacturingOrderShipping[]
  purchaseOrderOsds           PurchaseOrderOsd[]
  statusLogs                  OrderStatusLog[]

  @@index([storeId, status])
  @@index([storeId, number])
  @@index([storeId, createdAt])
}

model WarehouseOrder {
  id          String               @id @default(uuid()) @db.Uuid
  number      Int                  @unique @default(autoincrement())
  name        String
  status      WarehouseOrderStatus @default(open)
  documentKey String?
  warehouseId String               @db.Uuid
