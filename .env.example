# PostgreSQL (used by Prisma CLI + app via prisma.config.ts / process.env)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public"

# Public site URL (optional; used by lib/axios.ts default baseURL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js — generate secret: openssl rand -base64 32
AUTH_SECRET=""
# Must match how you open the app (this repo uses `next dev -p 4000`)
AUTH_URL="http://localhost:4000"

# Keycloak OIDC client (confidential). Issuer includes realm, e.g.:
# https://keycloak.example/realms/my-realm
AUTH_KEYCLOAK_ID=""
AUTH_KEYCLOAK_SECRET=""
AUTH_KEYCLOAK_ISSUER=""

# Keycloak Admin client for distributor Sale Channel login provisioning.
# Client must be able to manage users in the configured realm.
AUTH_KEYCLOAK_ADMIN_CLIENT_ID=""
AUTH_KEYCLOAK_ADMIN_CLIENT_SECRET=""

# DeepSeek assistant (server-side only)
DEEPSEEK_API_KEY=""
# Optional; defaults to https://api.deepseek.com
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# DEEPSEEK_MODEL="deepseek-chat"

# Shopify inventory integration (server-side only)
# pgcrypto passphrase for Shopify token/webhook-secret encryption. Keep stable.
# If secrets were saved before pgcrypto, keep the old base64 32-byte value until they are re-encrypted.
SHOPIFY_INTEGRATION_ENCRYPTION_KEY=""
# Optional webhook callback base URL. Shopify requires public HTTPS, not localhost or a Shopify domain.
# For local webhooks, set this to an HTTPS tunnel that forwards to http://localhost:4000.
# SHOPIFY_WEBHOOK_BASE_URL="https://your-tunnel.example"
# Optional; defaults enabled. Set to false to disable the in-process hourly sync and daily stock backups.
# SHOPIFY_INTERNAL_SYNC_ENABLED=true

# CJdropshipping inventory integration (server-side only)
# pgcrypto passphrase for CJ API key/token encryption. Keep stable.
CJDROPSHIPPING_INTEGRATION_ENCRYPTION_KEY=""
# Optional; defaults enabled. Set to false to disable the in-process CJ inventory sync.
# CJDROPSHIPPING_INTERNAL_SYNC_ENABLED=true
# Optional; defaults to 1100ms to stay under CJ's low-tier 1 request/second limit.
# CJDROPSHIPPING_REQUEST_INTERVAL_MS=1100

# Assistant behavior / safeguards
# ASSISTANT_TIMEOUT_MS=20000
# ASSISTANT_MAX_HISTORY_MESSAGES=10
# ASSISTANT_MAX_MESSAGE_CHARS=2000
# ASSISTANT_TOOL_MAX_STEPS=4
# ASSISTANT_RATE_LIMIT_MAX=8
# ASSISTANT_RATE_LIMIT_WINDOW_MS=60000

# Email (server-side only)
# Defaults to smtp in development and sendgrid in production.
# For local MailHog, run MailHog on SMTP localhost:1025.
# Docker development overrides SMTP_HOST to mailhog inside docker-compose.dev.yml.
# EMAIL_TRANSPORT="smtp"
SMTP_HOST="localhost"
SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=""
# SMTP_PASSWORD=""

# SendGrid production email
SENDGRID_API_KEY=""
# Must be a SendGrid-verified sender.
EMAIL_FROM=""
# EMAIL_FROM_NAME="PO App"
# EMAIL_REPLY_TO=""
# EMAIL_REPLY_TO_NAME=""
# Optional; defaults to https://api.sendgrid.com/v3/mail/send
# SENDGRID_MAIL_SEND_URL="https://api.sendgrid.com/v3/mail/send"

# Optional bearer token for POST /api/notifications/email-deliveries/dispatch
# NOTIFICATION_DISPATCH_TOKEN=""

# Payment provider credential encryption (server-side only)
# pgcrypto passphrase for per-store Stripe secret/webhook-secret encryption. Keep stable.
PAYMENT_PROVIDER_ENCRYPTION_KEY=""

# Stripe Checkout for distributor New Order payments.
# Stripe keys are saved per store in Settings > Integrations. For local webhooks:
# stripe listen --forward-to localhost:4000/api/payments/stripe/webhook

# MinIO / S3-compatible object storage (server-side SDK + presigned URLs)
# Console default: http://localhost:9001 — S3 API: http://localhost:9000 (do not use :9001 here;
# MinIO returns "S3 API Requests must be made to API port." The app maps :9001 → :9000 if mis-set.)
MINIO_ENDPOINT="http://localhost:9000"
# If browsers use a different host than the server (optional), set this for presigned URLs
# MINIO_PUBLIC_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET="po-app-uploads"
# MINIO_REGION="us-east-1"

# Optional limits (defaults shown)
# STORAGE_MAX_UPLOAD_BYTES=10485760
# STORAGE_PRESIGN_EXPIRES_SECONDS=900
# PO email PDF links default to the S3/MinIO SigV4 max of 7 days.
# PO_EMAIL_PDF_URL_EXPIRES_SECONDS=604800
